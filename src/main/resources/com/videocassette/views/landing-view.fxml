<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<!-- landing-view.fxml : C'est la toute première page que l'on voit en ouvrant le logiciel.
    Elle sert d'écran d'accueil pour choisir entre se connecter ou créer un compte. -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.videocassette.controller.LandingController"
           styleClass="login-background"
           prefWidth="900" prefHeight="600">

    <!-- VBox aligne les éléments verticalement (les uns sous les autres) -->
    <VBox alignment="CENTER" spacing="30">
        <padding><Insets top="40" right="15" bottom="40" left="15"/></padding>

        <!-- Section du titre et du logo -->
        <VBox alignment="CENTER" spacing="10">
            <Label text="🎬" style="-fx-font-size: 80px;"/>
            <Label text="Video Club" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Votre destination préférée pour le cinéma vintage" 
                   style="-fx-font-size: 18px; -fx-text-fill: #E0E1DD; -fx-opacity: 0.9;"/>
        </VBox>

        <!-- Carte centrale contenant les boutons d'action -->

        <VBox alignment="CENTER" spacing="15" styleClass="login-card" style="-fx-background-color: rgba(255, 255, 255, 0.9);" maxWidth="800">
            <padding><Insets top="35" right="50" bottom="35" left="50"/></padding>
            
            <Label text="Système d'information dédié à la gestion des locations de cassettes, au suivi des abonnés et au contrôle des retours." 
                   wrapText="true" textAlignment="CENTER" style="-fx-font-size: 20px; -fx-text-fill: #415A77;"/>
            
            <Region prefHeight="10"/>

            <!-- HBox aligne les boutons horizontalement -->
            <HBox spacing="15" alignment="CENTER">
                <!-- onAction="#goToLogin" appelle la méthode goToLogin() dans le contrôleur -->
                <Button text="Se Connecter" styleClass="login-button" onAction="#goToLogin" 
                        prefWidth="160" prefHeight="45" style="-fx-min-width: 160;"/>
                <Button text="S'inscrire" styleClass="action-button-secondary" onAction="#goToRegister" 
                        prefWidth="160" prefHeight="45" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
            </HBox>
            
            <Button text="Nous Contacter" onAction="#showContactInfo" 
                    styleClass="landing-link" style="-fx-background-color: transparent;"/>
        </VBox>

        <!-- Bloc d'informations de contact (caché par défaut) -->

        <VBox fx:id="contactBox" alignment="CENTER" spacing="10" 
              style="-fx-background-color: rgba(27, 40, 56, 0.8); -fx-background-radius: 12; -fx-padding: 20;" 
              visible="false" managed="false">
            <Label text=" 123 Rue du Cinéma, Bd 30 Août ADIDOGOME" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Label text=" +228 99 70 70 99" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Label text=" bester@videoclub.org" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
        </VBox>

    </VBox>
</StackPane>
