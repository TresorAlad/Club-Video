<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- contact-view.fxml : Fenêtre de contact.
    Elle permet aux utilisateurs d'envoyer un message aux administrateurs. -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.videocassette.controller.ContactController"
           styleClass="login-background"
           prefWidth="900" prefHeight="600">

    <VBox alignment="CENTER" spacing="20" maxWidth="500">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <VBox alignment="CENTER" spacing="10">
            <Label text="Nous Contacter" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="N'hésitez pas à nous envoyer un message" 
                   style="-fx-font-size: 16px; -fx-text-fill: #E0E1DD; -fx-opacity: 0.9;"/>
        </VBox>

        <HBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(27, 40, 56, 0.8); -fx-background-radius: 12; -fx-padding: 20;">
            <VBox spacing="10" alignment="CENTER_LEFT">
                <Label text=" 123 Rue du Cinéma, Bd 30 Août ADIDOGOME" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label text=" +228 99 70 70 99" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <Label text=" bester@videoclub.org" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            </VBox>
        </HBox>

        <VBox alignment="CENTER" spacing="15" styleClass="login-card" style="-fx-background-color: rgba(255, 255, 255, 0.95); -fx-background-radius: 12; -fx-padding: 25;">
            
            <TextField fx:id="nameField" promptText="Votre Nom Complet" styleClass="login-field" 
                       style="-fx-font-size: 14px; -fx-pref-height: 40px;"/>
                       
            <TextField fx:id="emailField" promptText="Votre Adresse Email" styleClass="login-field" 
                       style="-fx-font-size: 14px; -fx-pref-height: 40px;"/>
                       
            <TextArea fx:id="messageArea" promptText="Votre Message" wrapText="true" 
                      styleClass="login-field" style="-fx-font-size: 14px; -fx-pref-height: 100px; -fx-pref-row-count: 4;"/>

            <Region prefHeight="5"/>

            <Button text="Envoyer le Message" styleClass="login-button" onAction="#envoyerMessage" 
                    prefWidth="250" prefHeight="45" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
            
            <Button text="Retour à l'Accueil" styleClass="action-button-secondary" onAction="#goToLanding" 
                    prefWidth="250" prefHeight="45" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                    
        </VBox>

    </VBox>
</StackPane>
