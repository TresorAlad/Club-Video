<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- category-form-view.fxml : Formulaire pour gérer les catégories de films. -->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.videocassette.controller.CategoryFormController"
      spacing="30" alignment="CENTER" styleClass="content-area"
      prefWidth="1100" prefHeight="700">
    
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <VBox spacing="25" maxWidth="500" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 10);">
        
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label fx:id="pageTitle" text="Ajouter une catégorie" styleClass="content-title" style="-fx-font-size: 22px;"/>
        </HBox>

        <VBox spacing="8">
            <Label text="Nom de la catégorie" styleClass="form-label"/>
            <TextField fx:id="libelleField" styleClass="form-field" promptText="Ex: Action, Comédie..." prefHeight="45"/>
        </VBox>

        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button text="Annuler" styleClass="action-button-secondary" onAction="#handleCancel" prefWidth="120" prefHeight="40"/>
            <Button text="Enregistrer" styleClass="action-button" onAction="#handleSave" prefWidth="120" prefHeight="40"/>
        </HBox>
    </VBox>

</VBox>
