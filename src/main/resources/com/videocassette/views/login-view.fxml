<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- login-view.fxml : Fenêtre de connexion.
    Elle permet à l'utilisateur de saisir son email et son mot de passe pour entrer dans le système. -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.videocassette.controller.LoginController"
           styleClass="login-background"
           prefWidth="900" prefHeight="600">

    <VBox styleClass="login-card" alignment="CENTER" spacing="8" maxWidth="420">
        <StackPane.margin><Insets top="30" bottom="30"/></StackPane.margin>
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <!-- Bouton retour vers l'accueil -->
        <HBox alignment="CENTER_LEFT">
            <Button text="← Retour" onAction="#goToLanding" style="-fx-background-color: transparent; -fx-text-fill: #778DA9; -fx-cursor: hand;"/>
        </HBox>

        <Label text="🎬 Video Club" styleClass="login-title"/>
        <Label text="Connectez-vous pour accéder au système" styleClass="login-subtitle"/>

        <Region prefHeight="20"/>

        <Label text="Adresse email" styleClass="form-label" maxWidth="Infinity" alignment="CENTER_LEFT"/>
        <TextField fx:id="emailField" styleClass="login-field"
                   promptText="Entrez votre email" prefHeight="42"/>

        <Region prefHeight="6"/>

        <!-- Section du mot de passe avec option pour voir/masquer -->
        <Label text="Mot de passe" styleClass="form-label" maxWidth="Infinity" alignment="CENTER_LEFT"/>
        <HBox spacing="0" alignment="CENTER_LEFT">
            <StackPane HBox.hgrow="ALWAYS">
                <!-- PasswordField cache les caractères par des points -->
                <PasswordField fx:id="passwordField" styleClass="login-field"
                               promptText="Entrez votre mot de passe" prefHeight="42"/>
                <!-- TextField affiche le mot de passe en clair (caché par défaut) -->
                <TextField fx:id="passwordTextField" styleClass="login-field"
                           promptText="Entrez votre mot de passe" prefHeight="42" visible="false"/>
            </StackPane>
            <Button fx:id="togglePasswordBtn" onAction="#togglePasswordVisibility" prefHeight="42" text="Voir" style="-fx-background-color: transparent; -fx-border-color: #ced4da; -fx-border-width: 1 1 1 0; -fx-border-radius: 0 4 4 0; -fx-cursor: hand; -fx-font-size: 16px;"/>
        </HBox>

        <Region prefHeight="6"/>

        <Label fx:id="errorLabel" styleClass="login-error" text="" wrapText="true"/>

        <Region prefHeight="10"/>

        <Button text="Se Connecter" styleClass="login-button"
                onAction="#handleLogin" prefHeight="44" maxWidth="Infinity"/>

        <Region prefHeight="5"/>
        
        <Hyperlink text="Pas encore de compte ? S'inscrire" onAction="#goToRegister" style="-fx-text-fill: #415A77;"/>

        <Region prefHeight="10"/>
    </VBox>
</StackPane>
