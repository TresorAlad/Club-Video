<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.videocassette.controller.DashboardController"
      prefWidth="1100" prefHeight="700">

    <!-- ============ SIDEBAR ============ -->
    <VBox styleClass="sidebar" spacing="2">
        <VBox styleClass="sidebar-header">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2v-video-vintage" iconSize="26" iconColor="white"/>
                <Label text="Video Club" styleClass="sidebar-title"/>
            </HBox>
        </VBox>

        <Region prefHeight="10"/>

        <Button text="Accueil" styleClass="nav-button" onAction="#showAccueil" fx:id="btnAccueil">
            <graphic><FontIcon iconLiteral="mdi2h-home-outline" iconSize="18" iconColor="#C8CDD3"/></graphic>
            <padding><Insets top="13" right="24" bottom="13" left="16"/></padding>
        </Button>

        <Button text="Cassettes" styleClass="nav-button" onAction="#showCassettes" fx:id="btnCassettes">
            <graphic><FontIcon iconLiteral="mdi2v-video-box" iconSize="18" iconColor="#C8CDD3"/></graphic>
            <padding><Insets top="13" right="24" bottom="13" left="16"/></padding>
        </Button>

        <Button text="Abonnés" styleClass="nav-button" onAction="#showAbonnes" fx:id="btnAbonnes">
            <graphic><FontIcon iconLiteral="mdi2a-account-multiple-outline" iconSize="18" iconColor="#C8CDD3"/></graphic>
            <padding><Insets top="13" right="24" bottom="13" left="16"/></padding>
        </Button>

        <Button text="Catégories" styleClass="nav-button" onAction="#showCategories" fx:id="btnCategories">
            <graphic><FontIcon iconLiteral="mdi2t-tag-multiple-outline" iconSize="18" iconColor="#C8CDD3"/></graphic>
            <padding><Insets top="13" right="24" bottom="13" left="16"/></padding>
        </Button>

        <Button text="Locations" styleClass="nav-button" onAction="#showLocations" fx:id="btnLocations">
            <graphic><FontIcon iconLiteral="mdi2c-clipboard-list-outline" iconSize="18" iconColor="#C8CDD3"/></graphic>
            <padding><Insets top="13" right="24" bottom="13" left="16"/></padding>
        </Button>

        <Button text="Statistiques" styleClass="nav-button" onAction="#showStatistiques" fx:id="btnStats">
            <graphic><FontIcon iconLiteral="mdi2c-chart-bar" iconSize="18" iconColor="#C8CDD3"/></graphic>
            <padding><Insets top="13" right="24" bottom="13" left="16"/></padding>
        </Button>

        <Button text="Profil" styleClass="nav-button" onAction="#showProfil" fx:id="btnProfil">
            <graphic><FontIcon iconLiteral="mdi2a-account-circle-outline" iconSize="18" iconColor="#C8CDD3"/></graphic>
            <padding><Insets top="13" right="24" bottom="13" left="16"/></padding>
        </Button>

        <Region VBox.vgrow="ALWAYS"/>
        <VBox alignment="CENTER" spacing="0">
            <padding><Insets top="0" right="20" bottom="20" left="20"/></padding>
            <Button text="Déconnecter" styleClass="nav-button-disconnect" onAction="#deconnecter" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="mdi2l-logout" iconSize="16" iconColor="white"/></graphic>
            </Button>
        </VBox>
    </VBox>

    <!-- ============ CONTENU ============ -->
    <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS" styleClass="content-area">

        <!-- ===== ACCUEIL ===== -->
        <VBox fx:id="accueilPane" spacing="20" VBox.vgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2h-home" iconSize="28" iconColor="#415A77"/>
                <Label text="Tableau de Bord" styleClass="content-title"/>
            </HBox>
            <Label text="Bienvenue dans le système de gestion Video Club" styleClass="content-subtitle"/>
            <Region prefHeight="4"/>

            <!-- Cartes statistiques -->
            <HBox spacing="16">
                <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="mdi2v-video-box" iconSize="22" iconColor="#415A77"/>
                    <Label fx:id="statCassettes" text="0" styleClass="stat-value"/>
                    <Label text="Cassettes" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="mdi2a-account-multiple" iconSize="22" iconColor="#415A77"/>
                    <Label fx:id="statAbonnes" text="0" styleClass="stat-value"/>
                    <Label text="Abonnés" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="mdi2c-clipboard-list" iconSize="22" iconColor="#415A77"/>
                    <Label fx:id="statLocationsActives" text="0" styleClass="stat-value"/>
                    <Label text="Locations Actives" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="mdi2t-tag-multiple" iconSize="22" iconColor="#415A77"/>
                    <Label fx:id="statCategories" text="0" styleClass="stat-value"/>
                    <Label text="Catégories" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <!-- Séparateur titre catalogue -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2v-video-box" iconSize="20" iconColor="#415A77"/>
                <Label text="Catalogue des Cassettes" style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1B2838;"/>
            </HBox>

            <!-- Filtres catégorie + recherche -->
            <HBox styleClass="toolbar-box" alignment="CENTER_LEFT" spacing="16">
                <HBox styleClass="category-filter-box" alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="mdi2f-filter-outline" iconSize="16" iconColor="#415A77"/>
                    <Label text="Catégories :" style="-fx-font-weight: bold; -fx-text-fill: #1B2838;" minWidth="-Infinity"/>
                    <ScrollPane vbarPolicy="NEVER" hbarPolicy="NEVER" style="-fx-background-color: transparent;" fitToHeight="true" pannable="true" HBox.hgrow="ALWAYS">
                        <HBox fx:id="categoryFilterBox" spacing="8" alignment="CENTER_LEFT"/>
                    </ScrollPane>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="search-box-wrap">
                    <FontIcon iconLiteral="mdi2m-magnify" iconSize="16" iconColor="#778DA9"/>
                    <TextField fx:id="searchCassette" styleClass="search-field" promptText="Rechercher une cassette..." minWidth="220"/>
                </HBox>
            </HBox>

            <!-- Catalogue cassettes (cartes) -->
            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <FlowPane fx:id="cassettesFlowPane" hgap="20" vgap="20">
                    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                </FlowPane>
            </ScrollPane>
        </VBox>

        <!-- ===== CASSETTES (Gestion - TableView) ===== -->
        <VBox fx:id="cassettesPane" spacing="14" visible="false" managed="false" VBox.vgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2v-video-box" iconSize="28" iconColor="#415A77"/>
                <Label text="Gestion des Cassettes" styleClass="content-title"/>
            </HBox>
            <HBox styleClass="toolbar-box" alignment="CENTER_LEFT" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="mdi2m-magnify" iconSize="16" iconColor="#778DA9"/>
                    <TextField fx:id="searchCassetteTable" styleClass="search-field" promptText="Rechercher..." HBox.hgrow="ALWAYS"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button styleClass="action-button" onAction="#ajouterCassette">
                    <graphic><FontIcon iconLiteral="mdi2p-plus-circle-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                </Button>
                <Button styleClass="action-button-secondary" onAction="#modifierCassetteSelecTable">
                    <graphic><FontIcon iconLiteral="mdi2p-pencil-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                </Button>
                <Button styleClass="action-button-danger" onAction="#supprimerCassetteSelecTable">
                    <graphic><FontIcon iconLiteral="mdi2d-delete-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                </Button>
            </HBox>
            <TableView fx:id="cassetteTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="cassIdCol" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="cassTitreCol" text="Titre" prefWidth="200"/>
                    <TableColumn fx:id="cassDureeCol" text="Durée" prefWidth="100"/>
                    <TableColumn fx:id="cassCatCol" text="Catégorie" prefWidth="130"/>
                    <TableColumn fx:id="cassPrixCol" text="Prix" prefWidth="90"/>
                    <TableColumn fx:id="cassDateCol" text="Date Achat" prefWidth="110"/>
                    <TableColumn fx:id="cassDispoCol" text="Disponible" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>

        <!-- ===== ABONNÉS ===== -->
        <VBox fx:id="abonnesPane" spacing="14" visible="false" managed="false" VBox.vgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2a-account-multiple" iconSize="28" iconColor="#415A77"/>
                <Label text="Gestion des Abonnés" styleClass="content-title"/>
            </HBox>
            <HBox styleClass="toolbar-box">
                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="mdi2m-magnify" iconSize="16" iconColor="#778DA9"/>
                    <TextField fx:id="searchAbonne" styleClass="search-field" promptText="Rechercher un abonné..." HBox.hgrow="ALWAYS"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button styleClass="action-button" onAction="#ajouterAbonne">
                    <graphic><FontIcon iconLiteral="mdi2a-account-plus-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                </Button>
                <Button styleClass="action-button-secondary" onAction="#modifierAbonne">
                    <graphic><FontIcon iconLiteral="mdi2a-account-edit-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                </Button>
                <Button styleClass="action-button-danger" onAction="#supprimerAbonne">
                    <graphic><FontIcon iconLiteral="mdi2a-account-remove-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                </Button>
            </HBox>
            <TableView fx:id="abonneTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="abIdCol" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="abNomCol" text="Nom" prefWidth="180"/>
                    <TableColumn fx:id="abAdresseCol" text="Adresse" prefWidth="200"/>
                    <TableColumn fx:id="abDateAbCol" text="Date Abonnement" prefWidth="130"/>
                    <TableColumn fx:id="abDateEntCol" text="Date Entrée" prefWidth="120"/>
                    <TableColumn fx:id="abNbLocCol" text="Nb Locations" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>

        <!-- ===== CATÉGORIES ===== -->
        <VBox fx:id="categoriesPane" spacing="14" visible="false" managed="false" VBox.vgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2t-tag-multiple" iconSize="28" iconColor="#415A77"/>
                <Label text="Gestion des Catégories" styleClass="content-title"/>
            </HBox>
            <HBox styleClass="toolbar-box">
                <Region HBox.hgrow="ALWAYS"/>
                <Button styleClass="action-button" onAction="#ajouterCategorie">
                    <graphic><FontIcon iconLiteral="mdi2p-plus-circle-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                </Button>
                <Button styleClass="action-button-secondary" onAction="#modifierCategorie">
                    <graphic><FontIcon iconLiteral="mdi2p-pencil-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                </Button>
                <Button styleClass="action-button-danger" onAction="#supprimerCategorie">
                    <graphic><FontIcon iconLiteral="mdi2d-delete-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                </Button>
            </HBox>
            <TableView fx:id="categorieTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="catIdCol" text="ID" prefWidth="80"/>
                    <TableColumn fx:id="catLibelleCol" text="Libellé Catégorie" prefWidth="350"/>
                </columns>
            </TableView>
        </VBox>

        <!-- ===== LOCATIONS ===== -->
        <VBox fx:id="locationsPane" spacing="14" visible="false" managed="false" VBox.vgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2c-clipboard-list" iconSize="28" iconColor="#415A77"/>
                <Label text="Gestion des Locations" styleClass="content-title"/>
            </HBox>
            <HBox styleClass="toolbar-box">
                <Region HBox.hgrow="ALWAYS"/>
                <Button styleClass="action-button" onAction="#nouvelleLocation">
                    <graphic><FontIcon iconLiteral="mdi2p-plus-circle-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                </Button>
                <Button styleClass="action-button-success" onAction="#cloturerLocation">
                    <graphic><FontIcon iconLiteral="mdi2c-check-circle-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                </Button>
            </HBox>
            <TableView fx:id="locationTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="locIdCol" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="locCassetteCol" text="Cassette" prefWidth="180"/>
                    <TableColumn fx:id="locAbonneCol" text="Abonné" prefWidth="150"/>
                    <TableColumn fx:id="locDateAllocCol" text="Date Location" prefWidth="120"/>
                    <TableColumn fx:id="locDateRetCol" text="Date Retour" prefWidth="120"/>
                    <TableColumn fx:id="locStatutCol" text="Statut" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>

        <!-- ===== STATISTIQUES ===== -->
        <VBox fx:id="statistiquesPane" spacing="20" visible="false" managed="false">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2c-chart-bar" iconSize="28" iconColor="#415A77"/>
                <Label text="Statistiques" styleClass="content-title"/>
            </HBox>
            <HBox spacing="16">
                <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="mdi2v-video-box" iconSize="22" iconColor="#415A77"/>
                    <Label fx:id="statTotalCassettes2" text="0" styleClass="stat-value"/>
                    <Label text="Total Cassettes" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="mdi2a-account-multiple" iconSize="22" iconColor="#415A77"/>
                    <Label fx:id="statTotalAbonnes2" text="0" styleClass="stat-value"/>
                    <Label text="Total Abonnés" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="mdi2c-clipboard-list" iconSize="22" iconColor="#415A77"/>
                    <Label fx:id="statLocActives2" text="0" styleClass="stat-value"/>
                    <Label text="Locations Actives" styleClass="stat-label"/>
                </VBox>
            </HBox>
            <VBox styleClass="stat-card" spacing="10">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="mdi2i-information-outline" iconSize="18" iconColor="#415A77"/>
                    <Label text="Résumé" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B2838;"/>
                </HBox>
                <Label fx:id="statsResume" wrapText="true" style="-fx-text-fill: #555; -fx-font-size: 14px;"/>
            </VBox>
        </VBox>

        <!-- ===== PROFIL ===== -->
        <VBox fx:id="profilPane" spacing="20" visible="false" managed="false">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2a-account-circle" iconSize="28" iconColor="#415A77"/>
                <Label text="Mon Profil" styleClass="content-title"/>
            </HBox>
            <VBox styleClass="profil-card" spacing="16" maxWidth="500">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane styleClass="profil-avatar">
                        <FontIcon iconLiteral="mdi2a-account" iconSize="40" iconColor="white"/>
                    </StackPane>
                    <VBox spacing="4">
                        <Label fx:id="profilEmail" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B2838;"/>
                        <Label fx:id="profilRole" style="-fx-font-size: 13px; -fx-text-fill: #778DA9;"/>
                    </VBox>
                </HBox>

                <Separator/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="mdi2l-lock-outline" iconSize="16" iconColor="#415A77"/>
                    <Label text="Changer le mot de passe" styleClass="form-label"/>
                </HBox>
                <PasswordField fx:id="newPasswordField" styleClass="form-field" promptText="Nouveau mot de passe"/>
                <PasswordField fx:id="confirmPasswordField" styleClass="form-field" promptText="Confirmer le mot de passe"/>
                <Label fx:id="profilMessage" style="-fx-font-size: 12px;"/>
                <Button styleClass="action-button" onAction="#changerMotDePasse">
                    <graphic><FontIcon iconLiteral="mdi2c-content-save-outline" iconSize="16" iconColor="white"/></graphic>
                    <padding><Insets top="8" right="20" bottom="8" left="20"/></padding>
                </Button>
            </VBox>
        </VBox>

    </StackPane>
</HBox>
