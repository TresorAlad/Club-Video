<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- 
    rent-view.fxml : Fenêtre rapide pour louer une cassette à un abonné.
    Apparaît quand on clique sur "Louer" depuis une carte de cassette.
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.videocassette.controller.RentCassetteController"
      spacing="30" alignment="CENTER" styleClass="content-area"
      prefWidth="1100" prefHeight="700">
    
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <VBox spacing="25" maxWidth="500" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 10);">
        
        <VBox spacing="10" alignment="CENTER">
            <Label text="🎬" style="-fx-font-size: 50px;"/>
            <Label fx:id="cassetteTitleLabel" text="Louer une cassette" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1B2838;"/>
            <Label text="Sélectionnez l'abonné pour cette location" style="-fx-font-size: 14px; -fx-text-fill: #778DA9;"/>
        </VBox>

        <VBox spacing="8">
            <Label text="Code Abonné" styleClass="form-label"/>
            <TextField fx:id="codeAbonneField" styleClass="form-field" promptText="Ex: CLUB452" prefHeight="45"/>
        </VBox>

        <HBox spacing="15" alignment="CENTER">
            <Button text="Annuler" styleClass="action-button-secondary" onAction="#handleCancel" prefWidth="150" prefHeight="45"/>
            <Button text="Confirmer la Location" styleClass="action-button" onAction="#handleRent" prefWidth="200" prefHeight="45"/>
        </HBox>
    </VBox>

</VBox>
